# Copy this to .env and fill in your values
# Groq API (free): https://console.groq.com/keys
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# Ollama local fallback (optional — install ollama + pull llama3.2)
# If both are missing, the service uses structured template fallback (no LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Database (same SQLite as the backend)
DB_PATH=../api/skylearn_iq.db

# Port
PORT=8003
