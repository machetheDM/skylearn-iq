<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkyLearnIQ.Tutor.Views.SessionDetailPage"
    x:Name="Self"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SkyLearnIQ.Tutor.Models"
    Title="Session Detail"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Loading indicator -->
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#15803D" HorizontalOptions="Center" Margin="0,16" />

            <!-- Status message -->
            <Label Text="{Binding StatusMessage}"
                   TextColor="#15803D" FontSize="13" HorizontalOptions="Center"
                   IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
                   Margin="16,4,16,0" />

            <!-- Score hero card -->
            <Border BackgroundColor="#15803D" StrokeShape="RoundRectangle 0" Margin="0,0,0,16"
                    IsVisible="{Binding Session, Converter={StaticResource StringNotEmptyConverter}}"
                    Padding="24,20">
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Grid.Column="0" Spacing="4">
                        <Label Text="Session Score" FontSize="13" TextColor="#BBF7D0" />
                        <Label Text="{Binding Session.Score.PercentageDisplay, FallbackValue='—'}"
                               FontSize="42" FontAttributes="Bold" TextColor="White" />
                        <Label Text="{Binding Session.Score.PassFailDisplay, FallbackValue='Pending'}"
                               FontSize="14" TextColor="#BBF7D0" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center" Spacing="4">
                        <Label Text="{Binding Session.Score.TotalMarksAwarded, StringFormat='{0} / ', FallbackValue='—'}"
                               FontSize="18" TextColor="White" HorizontalOptions="End" />
                        <Label Text="{Binding Session.Score.TotalMarksPossible, StringFormat='{0} marks', FallbackValue=''}"
                               FontSize="13" TextColor="#BBF7D0" HorizontalOptions="End" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!-- Answers section -->
            <Label Text="Learner Answers" FontSize="16" FontAttributes="Bold"
                   TextColor="#0F172A" Margin="16,0,16,8" />

            <CollectionView ItemsSource="{Binding Answers}" Margin="16,0,16,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:AnswerOut">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 12"
                                Stroke="#E2E8F0" Padding="14" Margin="0,0,0,8">
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">

                                <Label Grid.Row="0" Grid.Column="0"
                                       Text="{Binding TextAnswer, FallbackValue='(MCQ selection)'}"
                                       FontSize="13" TextColor="#0F172A" FontAttributes="Bold" />

                                <Border Grid.Row="0" Grid.Column="1"
                                        StrokeShape="RoundRectangle 8" Padding="8,3"
                                        BackgroundColor="#F1F5F9">
                                    <Label Text="{Binding CorrectDisplay}" FontSize="11" TextColor="#64748B" />
                                </Border>

                                <Label Grid.Row="1" Grid.ColumnSpan="2"
                                       Text="{Binding MarksAwarded, StringFormat='Marks: {0}'}"
                                       FontSize="12" TextColor="#64748B" />

                                <!-- Mark button (for unmarked short answers) -->
                                <Button Grid.Row="2" Grid.ColumnSpan="2"
                                        Text="Mark This Answer"
                                        Command="{Binding Source={x:Reference Self}, Path=BindingContext.MarkAnswerCommand}"
                                        CommandParameter="{Binding .}"
                                        IsVisible="{Binding AutoMarked, Converter={StaticResource InvertBoolConverter}}"
                                        BackgroundColor="#2563EB"
                                        TextColor="White"
                                        FontSize="12"
                                        CornerRadius="8"
                                        HeightRequest="34"
                                        HorizontalOptions="Start"
                                        Padding="14,0" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Existing feedback -->
            <Label Text="Feedback" FontSize="16" FontAttributes="Bold"
                   TextColor="#0F172A" Margin="16,20,16,8"
                   IsVisible="{Binding Feedbacks.Count, Converter={StaticResource StringNotEmptyConverter}}" />

            <CollectionView ItemsSource="{Binding Feedbacks}" Margin="16,0,16,0">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:FeedbackOut">
                        <Border BackgroundColor="#F0FDF4" StrokeShape="RoundRectangle 12"
                                Stroke="#BBF7D0" Padding="14" Margin="0,0,0,8">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="{Binding SourceDisplay}" FontSize="12"
                                       FontAttributes="Bold" TextColor="#15803D" />
                                <Label Text="{Binding Content}" FontSize="13" TextColor="#0F172A" />
                                <Label Text="{Binding StrengthAreas, StringFormat='Strengths: {0}'}"
                                       FontSize="12" TextColor="#64748B"
                                       IsVisible="{Binding StrengthAreas, Converter={StaticResource StringNotEmptyConverter}}" />
                                <Label Text="{Binding WeaknessAreas, StringFormat='Weaknesses: {0}'}"
                                       FontSize="12" TextColor="#64748B"
                                       IsVisible="{Binding WeaknessAreas, Converter={StaticResource StringNotEmptyConverter}}" />
                                <Label Text="{Binding Recommendations, StringFormat='Recommendations: {0}'}"
                                       FontSize="12" TextColor="#64748B"
                                       IsVisible="{Binding Recommendations, Converter={StaticResource StringNotEmptyConverter}}" />
                            </VerticalStackLayout>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

            <!-- Add feedback form -->
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 14"
                    Stroke="#E2E8F0" Padding="16" Margin="16,16,16,24">
                <VerticalStackLayout Spacing="10">

                    <Label Text="Add Tutor Feedback" FontSize="15" FontAttributes="Bold" TextColor="#0F172A" />

                    <Label Text="Feedback (required)" FontSize="12" TextColor="#64748B" />
                    <Border StrokeShape="RoundRectangle 8" Stroke="#CBD5E1" Padding="4">
                        <Editor Text="{Binding FeedbackContent}" AutoSize="TextChanges"
                                MinimumHeightRequest="80" FontSize="13" BackgroundColor="Transparent" />
                    </Border>

                    <Label Text="Strengths (optional)" FontSize="12" TextColor="#64748B" />
                    <Border StrokeShape="RoundRectangle 8" Stroke="#CBD5E1" Padding="4">
                        <Editor Text="{Binding FbStrengths}" AutoSize="TextChanges"
                                MinimumHeightRequest="48" FontSize="13" BackgroundColor="Transparent" />
                    </Border>

                    <Label Text="Weaknesses (optional)" FontSize="12" TextColor="#64748B" />
                    <Border StrokeShape="RoundRectangle 8" Stroke="#CBD5E1" Padding="4">
                        <Editor Text="{Binding FbWeaknesses}" AutoSize="TextChanges"
                                MinimumHeightRequest="48" FontSize="13" BackgroundColor="Transparent" />
                    </Border>

                    <Label Text="Recommendations (optional)" FontSize="12" TextColor="#64748B" />
                    <Border StrokeShape="RoundRectangle 8" Stroke="#CBD5E1" Padding="4">
                        <Editor Text="{Binding FbRecommend}" AutoSize="TextChanges"
                                MinimumHeightRequest="48" FontSize="13" BackgroundColor="Transparent" />
                    </Border>

                    <Button Text="Save Feedback"
                            Command="{Binding AddFeedbackCommand}"
                            IsEnabled="{Binding IsBusy, Converter={StaticResource InvertBoolConverter}}"
                            BackgroundColor="#15803D"
                            TextColor="White"
                            FontAttributes="Bold"
                            FontSize="14"
                            CornerRadius="10"
                            HeightRequest="46"
                            Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
