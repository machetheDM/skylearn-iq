<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkyLearnIQ.Tutor.Views.AssessmentsPage"
    x:Name="Self"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SkyLearnIQ.Tutor.Models"
    Title="{Binding Title}"
    BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="Auto,Auto,*" Padding="16">

        <ActivityIndicator Grid.Row="0" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="#15803D" HorizontalOptions="Center" Margin="0,4" />

        <Label Grid.Row="1"
               Text="{Binding StatusMessage}"
               TextColor="#15803D"
               FontSize="13"
               IsVisible="{Binding StatusMessage, Converter={StaticResource StringNotEmptyConverter}}"
               Margin="0,0,0,8" />

        <CollectionView Grid.Row="2" ItemsSource="{Binding Assessments}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:AssessmentOut">
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 14"
                            Stroke="#E2E8F0" Padding="16" Margin="0,0,0,10">
                        <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,Auto" RowSpacing="6">

                            <!-- Title + Subject -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Title}"
                                   FontSize="15" FontAttributes="Bold" TextColor="#0F172A" />

                            <!-- Published badge -->
                            <Border Grid.Row="0" Grid.Column="1"
                                    StrokeShape="RoundRectangle 8" Padding="10,4"
                                    BackgroundColor="#94A3B8">
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsPublished}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#15803D" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Label Text="{Binding PublishedStatus}" FontSize="11" FontAttributes="Bold"
                                       TextColor="White" />
                            </Border>

                            <!-- Subject / marks / time -->
                            <HorizontalStackLayout Grid.Row="1" Grid.ColumnSpan="2" Spacing="16">
                                <Label Text="{Binding SubjectName}" FontSize="12" TextColor="#64748B" />
                                <Label Text="{Binding TotalMarks, StringFormat='{0} marks'}" FontSize="12" TextColor="#64748B" />
                                <Label Text="{Binding TimeLimitMin, StringFormat='{0} min'}" FontSize="12" TextColor="#64748B" />
                                <Label Text="{Binding QuestionCount, StringFormat='{0} questions'}" FontSize="12" TextColor="#64748B" />
                            </HorizontalStackLayout>

                            <!-- Publish button -->
                            <Button Grid.Row="2" Grid.Column="0"
                                    Text="Publish Assessment"
                                    Command="{Binding Source={x:Reference Self}, Path=BindingContext.PublishCommand}"
                                    CommandParameter="{Binding .}"
                                    IsEnabled="{Binding IsPublished, Converter={StaticResource InvertBoolConverter}}"
                                    BackgroundColor="#15803D"
                                    TextColor="White"
                                    FontSize="12"
                                    CornerRadius="8"
                                    HeightRequest="36"
                                    HorizontalOptions="Start"
                                    Padding="16,0" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
