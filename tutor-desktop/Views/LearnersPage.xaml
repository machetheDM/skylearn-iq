<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkyLearnIQ.Tutor.Views.LearnersPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SkyLearnIQ.Tutor.Models"
    Title="{Binding Title}"
    BackgroundColor="#F8FAFC">

    <Grid RowDefinitions="Auto,*" Padding="16">

        <ActivityIndicator Grid.Row="0" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                           Color="#15803D" HorizontalOptions="Center" Margin="0,8" />

        <CollectionView Grid.Row="1" ItemsSource="{Binding Learners}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:LearnerOut">
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 14"
                            Stroke="#E2E8F0" Padding="16" Margin="0,0,0,10">
                        <Grid ColumnDefinitions="48,*,Auto" ColumnSpacing="14">

                            <!-- Avatar circle -->
                            <Border Grid.Column="0"
                                    BackgroundColor="#DCFCE7"
                                    StrokeShape="RoundRectangle 24"
                                    WidthRequest="48" HeightRequest="48">
                                <Label Text="{Binding FullName[0]}" FontSize="20" FontAttributes="Bold"
                                       TextColor="#15803D" HorizontalOptions="Center" VerticalOptions="Center" />
                            </Border>

                            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                <Label Text="{Binding FullName}" FontSize="15" FontAttributes="Bold" TextColor="#0F172A" />
                                <Label Text="{Binding Phone}" FontSize="12" TextColor="#64748B" />
                                <Label Text="{Binding TrackDisplay}" FontSize="11" TextColor="#15803D" />
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Column="2" HorizontalOptions="End" VerticalOptions="Center" Spacing="4">
                                <Border BackgroundColor="#F0FDF4" StrokeShape="RoundRectangle 8"
                                        Stroke="#BBF7D0" Padding="8,4">
                                    <Label Text="{Binding GradeDisplay}" FontSize="13" FontAttributes="Bold"
                                           TextColor="#15803D" HorizontalOptions="Center" />
                                </Border>
                                <Label Text="{Binding TotalSessions, StringFormat='{0} sessions'}"
                                       FontSize="11" TextColor="#94A3B8" HorizontalOptions="End" />
                            </VerticalStackLayout>

                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>
</ContentPage>
