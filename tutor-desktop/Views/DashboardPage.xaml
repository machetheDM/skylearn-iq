<?xml version="1.0" encoding="UTF-8" ?>
<ContentPage
    x:Class="SkyLearnIQ.Tutor.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:SkyLearnIQ.Tutor.Models"
    Title="Dashboard"
    BackgroundColor="#F8FAFC">

    <ScrollView>
        <VerticalStackLayout Spacing="0">

            <!-- Hero header -->
            <Grid BackgroundColor="#15803D" Padding="24,20">
                <VerticalStackLayout>
                    <Label Text="{Binding TutorName, StringFormat='Welcome back, {0}!'}"
                           FontSize="22" FontAttributes="Bold" TextColor="White" />
                    <Label Text="SKYLearn IQ Tutor Portal — overview"
                           FontSize="13" TextColor="#BBF7D0" Margin="0,4,0,0" />
                </VerticalStackLayout>
            </Grid>

            <!-- Stats row -->
            <Grid ColumnDefinitions="*,*,*,*" Margin="16,-20,16,0" ColumnSpacing="10">
                <!-- Total -->
                <Border Grid.Column="0" BackgroundColor="White" StrokeShape="RoundRectangle 12"
                        Stroke="#E2E8F0" Padding="14">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding TotalSessions}" FontSize="26" FontAttributes="Bold"
                               TextColor="#0F172A" HorizontalOptions="Center" />
                        <Label Text="Total Sessions" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
                <!-- Completed -->
                <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 12"
                        Stroke="#E2E8F0" Padding="14">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding Completed}" FontSize="26" FontAttributes="Bold"
                               TextColor="#10B981" HorizontalOptions="Center" />
                        <Label Text="Completed" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
                <!-- In Progress -->
                <Border Grid.Column="2" BackgroundColor="White" StrokeShape="RoundRectangle 12"
                        Stroke="#E2E8F0" Padding="14">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding InProgress}" FontSize="26" FontAttributes="Bold"
                               TextColor="#F59E0B" HorizontalOptions="Center" />
                        <Label Text="In Progress" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
                <!-- Avg Score -->
                <Border Grid.Column="3" BackgroundColor="White" StrokeShape="RoundRectangle 12"
                        Stroke="#E2E8F0" Padding="14">
                    <VerticalStackLayout HorizontalOptions="Center" Spacing="2">
                        <Label Text="{Binding AvgScore}" FontSize="26" FontAttributes="Bold"
                               TextColor="#2563EB" HorizontalOptions="Center" />
                        <Label Text="Avg Score" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <!-- Recent sessions -->
            <Label Text="Recent Sessions" FontSize="16" FontAttributes="Bold"
                   TextColor="#0F172A" Margin="16,24,16,8" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               Color="#15803D" HorizontalOptions="Center" Margin="0,8" />

            <CollectionView ItemsSource="{Binding RecentSessions}" Margin="16,0,16,24">
                <CollectionView.ItemTemplate>
                    <DataTemplate x:DataType="models:SessionSummaryOut">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 12"
                                Stroke="#E2E8F0" Padding="14" Margin="0,0,0,8">
                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Grid.Column="0" Spacing="2">
                                    <Label Text="{Binding LearnerName}" FontSize="14"
                                           FontAttributes="Bold" TextColor="#0F172A" />
                                    <Label Text="{Binding AssessmentTitle}" FontSize="12" TextColor="#64748B" />
                                    <Label Text="{Binding DateDisplay}" FontSize="11" TextColor="#94A3B8" />
                                </VerticalStackLayout>
                                <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                                    <Label Text="{Binding ScoreDisplay}" FontSize="18" FontAttributes="Bold"
                                           TextColor="#15803D" HorizontalOptions="End" />
                                    <Label Text="{Binding StatusDisplay}" FontSize="11"
                                           TextColor="#64748B" HorizontalOptions="End" />
                                </VerticalStackLayout>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
