# SQLite source (same DB as the backend)
DB_PATH=../api/skylearn_iq.db

# Local Parquet output path (Bronze/Silver/Gold layers)
DATA_DIR=./data

# Azure Data Lake Storage Gen2 (needed only for cloud upload)
AZURE_STORAGE_ACCOUNT=skylearndatalake
AZURE_STORAGE_KEY=your_storage_key_here
AZURE_CONTAINER=skylearn-iq

# Azure Tenant / Subscription (needed for provision.sh)
AZURE_SUBSCRIPTION_ID=your_subscription_id
AZURE_RESOURCE_GROUP=rg-skylearn-iq
AZURE_LOCATION=southafricanorth
